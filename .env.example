# LZT API token from https://lolz.live/account/api
# Required scopes: read, post, market
LZT_API_TOKEN=your_lzt_api_token_here

# Telegram bot from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram chat ID (e.g. from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# Poll interval in seconds (min. 3 recommended due to API rate limits)
POLL_INTERVAL=3

# SQLite database path (use /app/data/scanner.db on Railway with a volume)
DB_PATH=data/scanner.db
